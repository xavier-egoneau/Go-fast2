{
  "mcpServers": {
    "orbit": {
      "command": "node",
      "args": ["./orbit/dist/index.js"],
      "env": {
        "MCP_ROOT_DIR": "."
      }
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {
        "X-Figma-Token": "${FIGMA_API_KEY}"
      }
    }
  }
}
