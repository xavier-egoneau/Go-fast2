<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ component.name|default('Composant') }} — Go-fast</title>
  <link rel="stylesheet" href="/app/styles/showcase.scss">
  <link rel="stylesheet" href="/dev/assets/scss/style.scss">
</head>
<body class="gf-body gf-body--isolated">

  <header class="gf-topbar">
    <a href="/" class="gf-topbar__back" aria-label="Retour au showcase">← Showcase</a>
    <div class="gf-topbar__info">
      <span class="gf-badge gf-badge--{{ component.level|default('atom') }}">{{ component.level|default('atom') }}</span>
      <h1 class="gf-topbar__title">{{ component.name|default('Composant') }}</h1>
      <span class="gf-topbar__category">{{ component.category|default('') }}</span>
    </div>
    <div class="gf-topbar__actions">
      <button class="gf-btn-icon" id="gf-toggle-controls" aria-label="Afficher/masquer les contrôles" aria-expanded="true">⚙</button>
      <button class="gf-btn-icon" id="gf-toggle-a11y" aria-label="Lancer le test accessibilité" title="Tester l'accessibilité (axe-core)">♿</button>
    </div>
  </header>

  <div class="gf-isolated-layout">

    <aside class="gf-controls" id="gf-controls" aria-label="Contrôles du composant">
      {% if component.description %}
        <p class="gf-controls__description">{{ component.description }}</p>
      {% endif %}

      <form class="gf-controls__form" id="gf-controls-form" novalidate>
        {% if component.variants %}
          <fieldset class="gf-fieldset">
            <legend class="gf-fieldset__legend">Variantes</legend>
            {# Les contrôles sont générés dynamiquement par showcase.js #}
          </fieldset>
        {% endif %}
        {% if component.content %}
          <fieldset class="gf-fieldset">
            <legend class="gf-fieldset__legend">Contenu</legend>
          </fieldset>
        {% endif %}
      </form>
    </aside>

    <main class="gf-preview-area" id="gf-preview-area">
      <div class="gf-preview" id="gf-preview" aria-label="Aperçu du composant">
        {# Rendu dynamique par showcase.js via fetch du template Twig compilé #}
      </div>
      <div class="gf-a11y-panel" id="gf-a11y-panel" hidden aria-label="Résultats accessibilité" aria-live="polite"></div>
    </main>

  </div>

  <script type="module" src="/app/scripts/showcase.js"></script>
  <script type="module" src="/app/scripts/quality.js"></script>
</body>
</html>
