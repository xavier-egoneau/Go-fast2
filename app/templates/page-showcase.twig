<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ component.name|default('Composant') }} — Go-fast</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
  <link rel="stylesheet" href="/app/styles/showcase.scss">
  <link rel="stylesheet" href="/node_modules/prismjs/themes/prism-tomorrow.css">
</head>
<body class="gf-body gf-body--isolated">

  <header class="gf-topbar">
    <a href="/" class="gf-topbar__back" aria-label="Retour au showcase">
      <span class="material-icons" aria-hidden="true">arrow_back</span>
      Showcase
    </a>
    <div class="gf-topbar__info">
      <span class="gf-badge gf-badge--atom" id="gf-item-badge">item</span>
      <h1 class="gf-topbar__title" id="gf-item-title">Aperçu</h1>
      <span class="gf-topbar__category" id="gf-item-category"></span>
    </div>
    <div class="gf-topbar__actions">
      <span class="gf-viewport-size" id="gf-viewport-size" aria-live="polite"></span>
      <a class="gf-btn-icon" id="gf-open-new-tab" target="_blank" rel="noopener" aria-label="Ouvrir dans un nouvel onglet">
        <span class="material-icons" aria-hidden="true">open_in_new</span>
      </a>
      <button class="gf-btn-icon" id="gf-toggle-code" aria-label="Afficher le code source" aria-expanded="false">
        <span class="material-icons" aria-hidden="true">code</span>
      </button>
      <button class="gf-btn-icon" id="gf-toggle-controls" aria-label="Afficher/masquer les contrôles" aria-expanded="true">
        <span class="material-icons" aria-hidden="true">tune</span>
      </button>
      <button class="gf-btn-icon" id="gf-toggle-a11y" aria-label="Lancer le test accessibilité" title="Tester l'accessibilité (axe-core)">
        <span class="material-icons" aria-hidden="true">accessibility</span>
      </button>
<button class="gf-btn-icon" id="gf-toggle-stress" aria-label="Activer le mode stress test" title="Stress test (contenu long / vide / overflow)">
        <span class="material-icons" aria-hidden="true">bug_report</span>
      </button>
    </div>
  </header>

  <div class="gf-isolated-layout">

    <aside class="gf-controls" id="gf-controls" aria-label="Contrôles du preview">
      <p class="gf-controls__description" id="gf-controls-description" hidden></p>

      <form class="gf-controls__form" id="gf-controls-form" novalidate>
        <fieldset class="gf-fieldset">
          <legend class="gf-fieldset__legend" id="gf-controls-label">Contrôles</legend>
        </fieldset>
      </form>
    </aside>

    <main class="gf-preview-area" id="gf-preview-area">
      <div class="gf-preview-container" id="gf-preview-container">
        <iframe
          id="gf-preview-frame"
          class="gf-preview-frame"
          title="Aperçu du composant"
          aria-label="Aperçu"
        ></iframe>
        <div class="gf-code-panel" id="gf-code-panel" hidden aria-label="Code source" role="region">
          <div class="gf-code-panel__toolbar">
            <span class="gf-code-panel__lang">HTML</span>
            <button class="gf-code-panel__copy" id="gf-copy-code" type="button">
              <span class="material-icons" aria-hidden="true">content_copy</span>
              Copier
            </button>
          </div>
          <pre class="gf-code-panel__pre language-html"><code class="language-html" id="gf-code-content"></code></pre>
        </div>
        <div class="gf-preview-error" id="gf-preview-error" hidden></div>
      </div>
      <div class="gf-a11y-panel" id="gf-a11y-panel" hidden aria-label="Résultats accessibilité" aria-live="polite"></div>
    </main>

  </div>

  <script src="/node_modules/prismjs/prism.js"></script>
  <script src="/node_modules/prismjs/components/prism-markup.min.js"></script>
  <script type="module" src="/app/scripts/showcase.js"></script>
  <script type="module" src="/app/scripts/quality.js"></script>
</body>
</html>
