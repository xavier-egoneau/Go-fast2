{% set size     = size|default('md') %}
{% set shape    = shape|default('circle') %}
{% set variant  = variant|default('primary') %}
{% set initials = initials|default('?') %}
{% set src      = src|default('') %}
{% set alt      = alt|default('Avatar') %}

<span class="avatar avatar--{{ size }} avatar--{{ shape }}{% if not src %} avatar--{{ variant }}{% endif %}" aria-label="{{ alt }}">
  {% if src %}
    <img class="avatar__img" src="{{ src }}" alt="{{ alt }}">
  {% else %}
    <span class="avatar__initials" aria-hidden="true">{{ initials }}</span>
  {% endif %}
</span>
