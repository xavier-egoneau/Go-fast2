{
  "name": "Badge",
  "level": "atom",
  "category": "Feedback",
  "description": "Étiquette colorée pour indiquer un statut, une catégorie ou un compteur.",
  "variants": {
    "variant": {
      "label": "Variante",
      "type": "select",
      "default": "primary",
      "options": ["primary", "secondary", "success", "danger", "warning", "neutral"]
    },
    "size": {
      "label": "Taille",
      "type": "select",
      "default": "md",
      "options": ["sm", "md", "lg"]
    },
    "rounded": {
      "label": "Arrondi complet",
      "type": "checkbox",
      "default": false
    },
    "dot": {
      "label": "Avec point",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "text": {
      "label": "Texte",
      "type": "text",
      "default": "Nouveau"
    }
  }
}
