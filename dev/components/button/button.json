{
  "name": "Button",
  "level": "atom",
  "category": "Forms",
  "description": "Élément d'action interactif. Supporte plusieurs variantes visuelles, tailles et états.",
  "variants": {
    "variant": {
      "label": "Variante",
      "type": "select",
      "default": "primary",
      "options": ["primary", "secondary", "outline", "ghost", "danger"]
    },
    "size": {
      "label": "Taille",
      "type": "select",
      "default": "md",
      "options": ["sm", "md", "lg"]
    },
    "full": {
      "label": "Pleine largeur",
      "type": "checkbox",
      "default": false
    },
    "disabled": {
      "label": "Désactivé",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "text": {
      "label": "Texte",
      "type": "text",
      "default": "Cliquez ici"
    }
  }
}
