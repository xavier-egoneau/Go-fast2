{% set id           = id|default('checkbox') %}
{% set name         = name|default(id) %}
{% set value        = value|default('1') %}
{% set label        = label|default('Option') %}
{% set checked      = checked|default(false) %}
{% set disabled     = disabled|default(false) %}
{% set required     = required|default(false) %}
{% set hasError     = hasError|default(false) %}
{% set errorMessage = errorMessage|default('Ce champ est requis.') %}

<div class="checkbox{% if disabled %} checkbox--disabled{% endif %}{% if hasError %} checkbox--error{% endif %}">

  <label class="checkbox__label" for="{{ id }}">
    <input
      class="checkbox__input"
      type="checkbox"
      id="{{ id }}"
      name="{{ name }}"
      value="{{ value }}"
      {% if checked %}checked{% endif %}
      {% if disabled %}disabled{% endif %}
      {% if required %}required aria-required="true"{% endif %}
      {% if hasError %}aria-invalid="true" aria-describedby="{{ id }}-error"{% endif %}
    >
    <span class="checkbox__box" aria-hidden="true"></span>
    <span class="checkbox__text">
      {{ label }}
      {% if required %}<span class="field__required" aria-hidden="true">*</span>{% endif %}
    </span>
  </label>

  {% if hasError %}
    <p class="field__error" id="{{ id }}-error" role="alert">{{ errorMessage }}</p>
  {% endif %}

</div>
