{% set variant   = variant|default('dark') %}
{% set logoText  = logoText|default('MonSite') %}
{% set tagline   = tagline|default('Construisons quelque chose de grand.') %}
{% set copyright = copyright|default('© 2025 MonSite. Tous droits réservés.') %}

{% set columns = columns|default([
  {
    title: 'Produit',
    links: [
      { label: 'Fonctionnalités', href: '#' },
      { label: 'Tarifs',          href: '#' },
      { label: 'Changelog',       href: '#' },
      { label: 'Roadmap',         href: '#' }
    ]
  },
  {
    title: 'Ressources',
    links: [
      { label: 'Documentation', href: '#' },
      { label: 'Blog',          href: '#' },
      { label: 'Tutoriels',     href: '#' },
      { label: 'Support',       href: '#' }
    ]
  },
  {
    title: 'Entreprise',
    links: [
      { label: 'À propos',  href: '#' },
      { label: 'Carrières', href: '#' },
      { label: 'Presse',    href: '#' },
      { label: 'Contact',   href: '#' }
    ]
  }
]) %}

{% set legalLinks = legalLinks|default([
  { label: 'Politique de confidentialité', href: '#' },
  { label: 'Conditions d\'utilisation',    href: '#' },
  { label: 'Cookies',                      href: '#' }
]) %}

<footer class="footer footer--{{ variant }}" role="contentinfo">
  <div class="footer__inner">

    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Retour à l'accueil">
        <span class="footer__logo-mark" aria-hidden="true">◈</span>
        <span class="footer__logo-name">{{ logoText }}</span>
      </a>
      {% if tagline %}
        <p class="footer__tagline">{{ tagline }}</p>
      {% endif %}
    </div>

    <nav class="footer__nav" aria-label="Navigation pied de page">
      {% for column in columns %}
        <div class="footer__col">
          <h3 class="footer__col-title">{{ column.title|default('') }}</h3>
          <ul class="footer__list" role="list">
            {% for link in column.links|default([]) %}
              <li class="footer__item">
                <a href="{{ link.href|default('#') }}" class="footer__link">
                  {{ link.label|default('') }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </nav>

  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__copyright">{{ copyright }}</p>
      {% if legalLinks %}
        <nav class="footer__legal" aria-label="Liens légaux">
          <ul class="footer__legal-list" role="list">
            {% for link in legalLinks %}
              <li>
                <a href="{{ link.href|default('#') }}" class="footer__legal-link">
                  {{ link.label|default('') }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}
    </div>
  </div>

</footer>
