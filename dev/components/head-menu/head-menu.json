{
  "name": "Head Menu",
  "level": "organism",
  "category": "Navigation",
  "description": "En-tête de navigation avec logo, liens, menu déroulant optionnel et bouton CTA. Supporte les thèmes clair/sombre, pleine largeur, transparent et responsive.",
  "variants": {
    "theme": {
      "label": "Thème",
      "type": "select",
      "default": "light",
      "options": ["light", "dark"]
    },
    "sticky": {
      "label": "Sticky",
      "type": "checkbox",
      "default": false
    },
    "fullWidth": {
      "label": "Pleine largeur",
      "type": "checkbox",
      "default": true
    },
    "transparent": {
      "label": "Fond transparent",
      "type": "checkbox",
      "default": false
    },
    "shadow": {
      "label": "Ombre (au lieu de border)",
      "type": "checkbox",
      "default": false
    },
    "navAlign": {
      "label": "Alignement des liens",
      "type": "select",
      "default": "right",
      "options": ["right", "center"]
    },
    "showButton": {
      "label": "Afficher le bouton CTA",
      "type": "checkbox",
      "default": true
    },
    "showMobileBurger": {
      "label": "Burger mobile visible (démo)",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "logoText": {
      "label": "Texte du logo",
      "type": "text",
      "default": "Logo"
    },
    "logoSrc": {
      "label": "Image du logo (URL)",
      "type": "text",
      "default": ""
    },
    "logoHref": {
      "label": "Lien du logo",
      "type": "text",
      "default": "#"
    },
    "activeItem": {
      "label": "Lien actif (label exact)",
      "type": "text",
      "default": "Accueil"
    },
    "buttonText": {
      "label": "Texte du bouton CTA",
      "type": "text",
      "default": "Commencer"
    },
    "buttonVariant": {
      "label": "Variante du bouton",
      "type": "text",
      "default": "primary"
    }
  }
}
