{% set theme            = theme|default('light') %}
{% set sticky           = sticky|default(false) %}
{% set fullWidth        = fullWidth|default(false) %}
{% set transparent      = transparent|default(false) %}
{% set shadow           = shadow|default(false) %}
{% set navAlign         = navAlign|default('right') %}
{% set showButton       = showButton|default(true) %}
{% set showMobileBurger = showMobileBurger|default(false) %}
{% set logoText         = logoText|default('Logo') %}
{% set logoSrc          = logoSrc|default('') %}
{% set logoHref         = logoHref|default('#') %}
{% set activeItem       = activeItem|default('') %}
{% set buttonText       = buttonText|default('Commencer') %}
{% set buttonVariant    = buttonVariant|default('primary') %}
{% set menuId           = menuId|default('head-menu-nav') %}
{% set items            = items|default([
  { label: 'Accueil', href: '#' },
  { label: 'Produit', href: '#' },
  {
    label: 'Solutions',
    children: [
      { label: 'Pour les équipes',       href: '#' },
      { label: 'Pour les entreprises',   href: '#' },
      { label: 'Pour les indépendants',  href: '#' }
    ]
  },
  { label: 'Tarifs',  href: '#' },
  { label: 'Contact', href: '#' }
]) %}

{# Classes modificatrices du header #}
{% set headerClasses = 'head-menu head-menu--' ~ theme %}
{% if sticky %}          {% set headerClasses = headerClasses ~ ' head-menu--sticky' %}        {% endif %}
{% if fullWidth %}       {% set headerClasses = headerClasses ~ ' head-menu--full-width' %}    {% endif %}
{% if transparent %}     {% set headerClasses = headerClasses ~ ' head-menu--transparent' %}   {% endif %}
{% if shadow %}          {% set headerClasses = headerClasses ~ ' head-menu--shadow' %}        {% endif %}
{% if showMobileBurger %}{% set headerClasses = headerClasses ~ ' head-menu--burger-open' %}   {% endif %}

<header class="{{ headerClasses }}" role="banner">
  <div class="head-menu__container">

    {# ── Logo ── #}
    <a class="head-menu__logo" href="{{ logoHref }}" aria-label="Retour à l'accueil">
      {% if logoSrc %}
        <img class="head-menu__logo-img" src="{{ logoSrc }}" alt="{{ logoText }}" />
      {% else %}
        <span class="head-menu__logo-text">{{ logoText }}</span>
      {% endif %}
    </a>

    {# ── Navigation ── #}
    <nav
      class="head-menu__nav head-menu__nav--{{ navAlign }}"
      id="{{ menuId }}"
      aria-label="Navigation principale"
    >
      <ul class="head-menu__list" role="list">
        {% for item in items %}
          {% set isActive = (activeItem is not empty and item.label == activeItem) %}
          {% set hasChildren = item.children is defined %}

          <li class="head-menu__item{% if hasChildren %} head-menu__item--has-dropdown{% endif %}">

            {% if hasChildren %}
              {# Trigger avec sous-menu #}
              <button
                class="head-menu__trigger{% if isActive %} head-menu__trigger--active{% endif %}"
                type="button"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {{ item.label }}
                <span class="head-menu__chevron" aria-hidden="true"></span>
              </button>

              <ul class="head-menu__dropdown" role="menu">
                {% for child in item.children %}
                  <li class="head-menu__dropdown-item" role="none">
                    <a
                      class="head-menu__dropdown-link"
                      href="{{ child.href|default('#') }}"
                      role="menuitem"
                    >
                      {% if child.icon is defined %}
                        <span class="head-menu__dropdown-icon" aria-hidden="true">{{ child.icon }}</span>
                      {% endif %}
                      {{ child.label }}
                    </a>
                  </li>
                {% endfor %}
              </ul>

            {% else %}
              {# Lien simple #}
              <a
                class="head-menu__link{% if isActive %} head-menu__link--active{% endif %}"
                href="{{ item.href|default('#') }}"
                {% if isActive %}aria-current="page"{% endif %}
              >
                {{ item.label }}
              </a>
            {% endif %}

          </li>
        {% endfor %}
      </ul>
    </nav>

    {# ── Bouton CTA ── #}
    {% if showButton %}
      <div class="head-menu__cta">
        <button class="btn btn--{{ buttonVariant }} btn--md" type="button">
          {{ buttonText }}
        </button>
      </div>
    {% endif %}

    {# ── Burger mobile ── #}
    <button
      class="head-menu__burger"
      type="button"
      aria-controls="{{ menuId }}"
      aria-expanded="{{ showMobileBurger ? 'true' : 'false' }}"
      aria-label="Ouvrir le menu"
    >
      <span class="head-menu__burger-bar" aria-hidden="true"></span>
      <span class="head-menu__burger-bar" aria-hidden="true"></span>
      <span class="head-menu__burger-bar" aria-hidden="true"></span>
    </button>

  </div>
</header>
