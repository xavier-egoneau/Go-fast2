{% set name  = name|default('placeholder') %}
{% set size  = size|default('md') %}
{% set label = label|default('') %}
{% set class = class|default('') %}

<svg
  class="icon icon--{{ size }}{% if class %} {{ class }}{% endif %}"
  {% if label %}role="img" aria-label="{{ label }}"{% else %}aria-hidden="true"{% endif %}
  focusable="false"
><use href="/dev/assets/icons/sprite.svg#icon-{{ name }}"></use></svg>
