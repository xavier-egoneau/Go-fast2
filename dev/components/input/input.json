{
  "name": "Input",
  "level": "atom",
  "category": "Forms",
  "description": "Champ de saisie texte, nombre ou date. Gère tous les états classiques : placeholder, disabled, error, required.",
  "variants": {
    "type": {
      "label": "Type",
      "type": "select",
      "default": "text",
      "options": ["text", "email", "password", "number", "date", "tel", "search"]
    },
    "size": {
      "label": "Taille",
      "type": "select",
      "default": "md",
      "options": ["sm", "md", "lg"]
    },
    "disabled": {
      "label": "Désactivé",
      "type": "checkbox",
      "default": false
    },
    "required": {
      "label": "Requis",
      "type": "checkbox",
      "default": false
    },
    "hasError": {
      "label": "Erreur",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "label": {
      "label": "Label",
      "type": "text",
      "default": "Adresse e-mail"
    },
    "placeholder": {
      "label": "Placeholder",
      "type": "text",
      "default": "ex : jean@exemple.fr"
    },
    "helpText": {
      "label": "Texte d'aide",
      "type": "text",
      "default": ""
    },
    "errorMessage": {
      "label": "Message d'erreur",
      "type": "text",
      "default": "Ce champ est invalide."
    }
  }
}
