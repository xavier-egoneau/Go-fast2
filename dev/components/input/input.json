{
  "name": "Input",
  "level": "atom",
  "category": "Forms",
  "description": "Champ de saisie de texte accessible.",
  "variants": {
    "type": {
      "label": "Type",
      "type": "select",
      "default": "text",
      "options": ["text", "email", "password", "number", "search", "tel", "url"]
    },
    "disabled": {
      "label": "Désactivé",
      "type": "checkbox",
      "default": false
    },
    "hasError": {
      "label": "Erreur",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "placeholder": {
      "label": "Placeholder",
      "type": "text",
      "default": "Saisissez une valeur..."
    },
    "id": {
      "label": "ID",
      "type": "text",
      "default": "field"
    }
  }
}
