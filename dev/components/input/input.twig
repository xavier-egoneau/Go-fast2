{% set type         = type|default('text') %}
{% set size         = size|default('md') %}
{% set id           = id|default('input-' ~ type) %}
{% set name         = name|default(id) %}
{% set label        = label|default('Label') %}
{% set placeholder  = placeholder|default('') %}
{% set value        = value|default('') %}
{% set disabled     = disabled|default(false) %}
{% set required     = required|default(false) %}
{% set hasError     = hasError|default(false) %}
{% set errorMessage = errorMessage|default('Ce champ est invalide.') %}
{% set helpText     = helpText|default('') %}

<div class="field{% if disabled %} field--disabled{% endif %}">

  <label class="field__label" for="{{ id }}">
    {{ label }}
    {% if required %}
      <span class="field__required" aria-hidden="true">*</span>
    {% endif %}
  </label>

  <input
    class="input input--{{ size }}{% if hasError %} input--error{% endif %}"
    type="{{ type }}"
    id="{{ id }}"
    name="{{ name }}"
    {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
    {% if value %}value="{{ value }}"{% endif %}
    {% if disabled %}disabled{% endif %}
    {% if required %}required aria-required="true"{% endif %}
    {% if hasError %}aria-invalid="true" aria-describedby="{{ id }}-error"
    {% elseif helpText %}aria-describedby="{{ id }}-help"{% endif %}
  >

  {% if hasError %}
    <p class="field__error" id="{{ id }}-error" role="alert">{{ errorMessage }}</p>
  {% elseif helpText %}
    <p class="field__help" id="{{ id }}-help">{{ helpText }}</p>
  {% endif %}

</div>
