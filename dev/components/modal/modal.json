{
  "name": "Modal",
  "level": "molecule",
  "category": "Feedback",
  "description": "Fenêtre modale centrée avec overlay, en-tête, corps et pied de page optionnel.",
  "variants": {
    "size": {
      "label": "Taille",
      "type": "select",
      "default": "md",
      "options": ["sm", "md", "lg", "xl"]
    },
    "open": {
      "label": "Ouverte",
      "type": "checkbox",
      "default": true
    },
    "showFooter": {
      "label": "Pied de page",
      "type": "checkbox",
      "default": true
    }
  },
  "content": {
    "title": {
      "label": "Titre",
      "type": "text",
      "default": "Confirmer l'action"
    },
    "body": {
      "label": "Contenu",
      "type": "text",
      "default": "Êtes-vous sûr de vouloir effectuer cette action ? Cette opération est irréversible."
    },
    "confirmLabel": {
      "label": "Bouton principal",
      "type": "text",
      "default": "Confirmer"
    },
    "cancelLabel": {
      "label": "Bouton secondaire",
      "type": "text",
      "default": "Annuler"
    }
  }
}
