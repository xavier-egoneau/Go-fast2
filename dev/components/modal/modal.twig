{% set open         = open|default(true) %}
{% set size         = size|default('md') %}
{% set showFooter   = showFooter|default(true) %}
{% set title        = title|default('Titre de la modale') %}
{% set body         = body|default('Contenu de la modale.') %}
{% set confirmLabel = confirmLabel|default('Confirmer') %}
{% set cancelLabel  = cancelLabel|default('Annuler') %}
{% set id           = id|default('modal-1') %}

<div
  class="modal{% if open %} modal--open{% endif %} modal--{{ size }}"
  id="{{ id }}"
  role="dialog"
  aria-modal="true"
  aria-labelledby="{{ id }}-title"
  {% if not open %}aria-hidden="true"{% endif %}
>
  <div class="modal__overlay" aria-hidden="true"></div>

  <div class="modal__dialog">
    <header class="modal__header">
      <h2 class="modal__title" id="{{ id }}-title">{{ title }}</h2>
      <button class="modal__close" type="button" aria-label="Fermer">
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <div class="modal__body">
      <p>{{ body }}</p>
    </div>

    {% if showFooter %}
    <footer class="modal__footer">
      <button class="btn btn--outline" type="button">{{ cancelLabel }}</button>
      <button class="btn btn--primary" type="button">{{ confirmLabel }}</button>
    </footer>
    {% endif %}
  </div>
</div>

<script>
(function () {
  var modal = document.getElementById('{{ id }}')
  if (!modal) return

  function closeModal() {
    modal.classList.remove('modal--open')
    modal.setAttribute('aria-hidden', 'true')
  }

  var closeBtn = modal.querySelector('.modal__close')
  if (closeBtn) closeBtn.addEventListener('click', closeModal)

  var overlay = modal.querySelector('.modal__overlay')
  if (overlay) overlay.addEventListener('click', closeModal)

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.classList.contains('modal--open')) closeModal()
  })
})()
</script>
