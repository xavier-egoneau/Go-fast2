{% set name         = name|default('radio-group') %}
{% set legend       = legend|default('Choisissez une option') %}
{% set value        = value|default('') %}
{% set disabled     = disabled|default(false) %}
{% set required     = required|default(false) %}
{% set hasError     = hasError|default(false) %}
{% set errorMessage = errorMessage|default('Veuillez choisir une option.') %}
{% set inline       = inline|default(false) %}
{% set errorId      = name ~ '-error' %}

{% set options = options|default([
  { value: 'mensuel',   label: 'Mensuel — 9 €/mois' },
  { value: 'annuel',    label: 'Annuel — 79 €/an' },
  { value: 'gratuit',   label: 'Gratuit — fonctions limitées' }
]) %}

<fieldset
  class="radio-group{% if inline %} radio-group--inline{% endif %}{% if disabled %} radio-group--disabled{% endif %}"
  {% if hasError %}aria-describedby="{{ errorId }}"{% endif %}
>
  <legend class="radio-group__legend">
    {{ legend }}
    {% if required %}<span class="field__required" aria-hidden="true">*</span>{% endif %}
  </legend>

  {% for option in options %}
    {% set optId = name ~ '-' ~ option.value|default(loop.index) %}
    <label class="radio__label" for="{{ optId }}">
      <input
        class="radio__input"
        type="radio"
        id="{{ optId }}"
        name="{{ name }}"
        value="{{ option.value|default('') }}"
        {% if value == option.value|default('') %}checked{% endif %}
        {% if disabled or option.disabled|default(false) %}disabled{% endif %}
        {% if required and loop.first %}required aria-required="true"{% endif %}
        {% if hasError %}aria-invalid="true"{% endif %}
      >
      <span class="radio__dot" aria-hidden="true"></span>
      <span class="radio__text">{{ option.label|default('') }}</span>
    </label>
  {% endfor %}

  {% if hasError %}
    <p class="field__error" id="{{ errorId }}" role="alert">{{ errorMessage }}</p>
  {% endif %}

</fieldset>
