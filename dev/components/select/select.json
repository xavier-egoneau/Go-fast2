{
  "name": "Select",
  "level": "atom",
  "category": "Forms",
  "description": "Liste déroulante avec flèche personnalisée. Gère placeholder, disabled, error et required.",
  "variants": {
    "size": {
      "label": "Taille",
      "type": "select",
      "default": "md",
      "options": ["sm", "md", "lg"]
    },
    "disabled": {
      "label": "Désactivé",
      "type": "checkbox",
      "default": false
    },
    "required": {
      "label": "Requis",
      "type": "checkbox",
      "default": false
    },
    "hasError": {
      "label": "Erreur",
      "type": "checkbox",
      "default": false
    }
  },
  "content": {
    "label": {
      "label": "Label",
      "type": "text",
      "default": "Pays"
    },
    "placeholder": {
      "label": "Placeholder",
      "type": "text",
      "default": "Choisissez un pays"
    },
    "helpText": {
      "label": "Texte d'aide",
      "type": "text",
      "default": ""
    },
    "errorMessage": {
      "label": "Message d'erreur",
      "type": "text",
      "default": "Veuillez sélectionner une option."
    }
  }
}
