{% set id       = id|default('switch') %}
{% set name     = name|default(id) %}
{% set label    = label|default('Activer') %}
{% set labelOn  = labelOn|default('Activé') %}
{% set labelOff = labelOff|default('Désactivé') %}
{% set checked  = checked|default(false) %}
{% set disabled = disabled|default(false) %}
{% set size     = size|default('md') %}

<div class="switch switch--{{ size }}{% if disabled %} switch--disabled{% endif %}">

  <label class="switch__label" for="{{ id }}">
    <input
      class="switch__input"
      type="checkbox"
      role="switch"
      id="{{ id }}"
      name="{{ name }}"
      {% if checked %}checked aria-checked="true"{% else %}aria-checked="false"{% endif %}
      {% if disabled %}disabled{% endif %}
    >
    <span class="switch__track" aria-hidden="true">
      <span class="switch__thumb"></span>
    </span>
    <span class="switch__text">{{ label }}</span>
  </label>

  <span class="switch__status" aria-live="polite">
    {{ checked ? labelOn : labelOff }}
  </span>

</div>
