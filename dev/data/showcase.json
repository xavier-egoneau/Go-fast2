        "text": {
          "label": "Description",
          "type": "text",
          "default": "Courte description du contenu de la carte."
        },
        "ctaText": {
          "label": "Texte du bouton",
          "type": "text",
          "default": "En savoir plus"
        }
      }
    },
    {
      "id": "checkbox",
      "path": "dev/components/checkbox/checkbox",
