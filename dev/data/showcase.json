{
  "components": [
    {
      "id": "button",
      "path": "dev/components/button/button",
      "name": "Button",
      "level": "atom",
      "category": "Forms",
      "description": "Élément d'action interactif. Supporte plusieurs variantes visuelles, tailles et états.",
      "variants": {
        "variant": {
          "label": "Variante",
          "type": "select",
          "default": "primary",
          "options": [
            "primary",
            "secondary",
            "outline",
            "ghost",
            "danger"
          ]
        },
        "size": {
          "label": "Taille",
          "type": "select",
          "default": "md",
          "options": [
            "sm",
            "md",
            "lg"
          ]
        },
        "full": {
          "label": "Pleine largeur",
          "type": "checkbox",
          "default": false
        },
        "disabled": {
          "label": "Désactivé",
          "type": "checkbox",
          "default": false
        }
      },
      "content": {
        "text": {
          "label": "Texte",
          "type": "text",
          "default": "Cliquez ici"
        }
      }
    },
    {
      "id": "card",
      "path": "dev/components/card/card",
      "name": "Card",
      "level": "molecule",
      "category": "Layout",
      "description": "Conteneur de contenu structuré avec image, titre, texte et action optionnels.",
      "variants": {
        "variant": {
          "label": "Variante",
          "type": "select",
          "default": "default",
          "options": [
            "default",
            "outlined",
            "elevated"
          ]
        },
        "horizontal": {
          "label": "Horizontal",
          "type": "checkbox",
          "default": false
        },
        "hasImage": {
          "label": "Avec image",
          "type": "checkbox",
          "default": true
        },
        "hasCta": {
          "label": "Avec bouton",
          "type": "checkbox",
          "default": true
        }
      },
      "content": {
        "title": {
          "label": "Titre",
          "type": "text",
          "default": "Titre de la carte"
