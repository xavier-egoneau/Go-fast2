      "content": {
        "label": {
          "label": "Label",
          "type": "text",
          "default": "J'accepte les conditions d'utilisation"
        },
        "errorMessage": {
          "label": "Message d'erreur",
          "type": "text",
          "default": "Vous devez accepter les conditions."
        }
      }
    },
